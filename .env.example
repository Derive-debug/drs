# ── Meta Ads API ──────────────────────────────────────────────
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
META_ACCESS_TOKEN=your_system_user_token

# Ad account IDs (without "act_" prefix — connector adds it automatically)
META_AD_ACCOUNTS=111111111,222222222,333333333

# Account → market mapping (JSON)
# US = single-market US account
# MX = single-market MX account
# Hybrid = mixed US+MX — will attempt country breakdown
META_ACCOUNT_MARKET_MAP={"111111111":"US","222222222":"MX","333333333":"Hybrid"}

# How to split hybrid accounts: "breakdown" (API country breakdown) or "mapping" (campaign name rules)
META_HYBRID_SPLIT_MODE=breakdown

# Campaign name → market mapping rules for "mapping" fallback mode (regex patterns, JSON)
META_CAMPAIGN_MARKET_RULES={"(?i)\\bus\\b|united.states|usa":"US","(?i)\\bmx\\b|mex|mexico":"MX"}

# ── GA4 ──────────────────────────────────────────────────────
# GA4_SA_KEY_PATH=data/.secrets/ga4-service-account.json
# GA4_PROPERTY_ID=471887604
